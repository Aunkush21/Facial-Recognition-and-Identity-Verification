.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# ---- Logs ----
*.log

# ---- Claude Code (local config) ----
.claude/

# ---- OS / editor ----
.DS_Store
Thumbs.db
.vscode/
.idea/
