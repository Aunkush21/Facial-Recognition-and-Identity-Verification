# Copy this file to .env and fill in real values. Never commit .env.

# --- Database ---
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/facial_recognition

# --- Auth / JWT ---
JWT_SECRET_KEY=changeme-generate-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Face engine ---
FACE_MODEL_PACK=buffalo_l
RECOGNITION_THRESHOLD=0.45
LIVENESS_THRESHOLD=0.65

# --- Consensus ---
# Browser polls ~1 frame/sec, so the window must comfortably exceed
# CONSENSUS_FRAMES_REQUIRED seconds or consensus never completes.
CONSENSUS_FRAMES_REQUIRED=5
CONSENSUS_WINDOW_SECONDS=10
